// Paint & Keep - Full Database Schema
// PostgreSQL with Prisma ORM
// Run `npx prisma migrate dev --name init` to create initial migration
// Run `npx prisma generate` to generate the Prisma Client

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum AgeGroup {
  AGES_4_6
  AGES_7_9
  AGES_10_12
  TEENS
  ADULTS
  FAMILY
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  STRIPE
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FEATURED
}

enum TagSource {
  MANUAL
  AI
}

enum ChallengeStatus {
  UPCOMING
  SUBMISSION
  VOTING
  COMPLETED
  EXTENDED
}

enum PackageTier {
  STARTER_10
  POPULAR_20
  MEGA_50
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ORDER_CONFIRMATION
  SHIPPING_UPDATE
  DELIVERY_CONFIRMATION
  PASSWORD_RESET
  EMAIL_VERIFICATION
  BADGE_EARNED
  ADMIN_NEW_ORDER
  ADMIN_LOW_STOCK
  ADMIN_NEW_INQUIRY
  ADMIN_MODERATION
  BIRTHDAY_INQUIRY_CONFIRMATION
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum AdminRole {
  SUPER_ADMIN
  OPERATIONS
  MARKETING
  CUSTOMER_SUPPORT
}

// ==================== USERS & AUTH ====================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String    @db.VarChar(100)
  passwordHash        String?
  phone               String?   @db.VarChar(20)
  profileImage        String?
  provider            AuthProvider @default(EMAIL)
  emailVerified       Boolean   @default(false)
  verificationToken   String?
  verificationExpiry  DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lifetimeSpend       Decimal   @default(0) @db.Decimal(12, 2)
  points              Int       @default(0)
  isActive            Boolean   @default(true)
  subscribedMarketing Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  addresses        Address[]
  orders           Order[]
  reviews          Review[]
  galleryPhotos    GalleryPhoto[]
  wishlistItems    WishlistItem[]
  badges           UserBadge[]
  sessions         Session[]
  cartItems        CartItem[]
  photoLikes       PhotoLike[]
  photoSaves       PhotoSave[]
  challengeEntries ChallengeEntry[]
  contestEntries   ContestEntry[]
  votes            Vote[]
  notifications    NotificationPreference[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  fullName   String   @db.VarChar(100)
  phone      String   @db.VarChar(15)
  line1      String   @db.VarChar(200)
  line2      String?  @db.VarChar(200)
  city       String   @db.VarChar(100)
  state      String   @db.VarChar(100)
  postalCode String   @db.VarChar(10)
  country    String   @db.VarChar(100)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ==================== PRODUCTS & INVENTORY ====================

model Product {
  id                String          @id @default(cuid())
  slug              String          @unique
  name              String          @db.VarChar(200)
  description       String          @db.VarChar(5000)
  price             Decimal         @db.Decimal(10, 2)
  categoryId        String
  ageGroup          AgeGroup
  difficultyLevel   DifficultyLevel
  stock             Int             @default(0)
  lowStockThreshold Int             @default(10)
  averageRating     Decimal         @default(0) @db.Decimal(2, 1)
  reviewCount       Int             @default(0)
  isPublished       Boolean         @default(false)
  isFeatured        Boolean         @default(false)
  seoTitle          String?         @db.VarChar(60)
  seoDescription    String?         @db.VarChar(160)
  videoUrl          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  orderItems    OrderItem[]
  reviews       Review[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique @db.VarChar(100)
  slug     String    @unique
  products Product[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String  @db.VarChar(200)
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ==================== ORDERS ====================

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String?
  guestEmail        String?
  addressId         String
  status            OrderStatus   @default(PENDING)
  subtotal          Decimal       @db.Decimal(12, 2)
  discount          Decimal       @default(0) @db.Decimal(12, 2)
  shippingCost      Decimal       @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  paymentId         String?
  couponId          String?
  giftNote          String?       @db.VarChar(250)
  trackingCarrier   String?
  trackingNumber    String?
  estimatedDelivery DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user          User?           @relation(fields: [userId], references: [id])
  address       Address         @relation(fields: [addressId], references: [id])
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  statusHistory StatusHistory[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model StatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  adminId   String?
  note      String?
  createdAt DateTime    @default(now())

  order Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin Admin? @relation(fields: [adminId], references: [id])
}

// ==================== COUPONS ====================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique @db.VarChar(20)
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal      @default(0) @db.Decimal(12, 2)
  maxUsage       Int
  currentUsage   Int          @default(0)
  expiryDate     DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  orders Order[]
  usages CouponUsage[]
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  orderId  String
  userId   String?
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
}

// ==================== GALLERY ====================

model GalleryPhoto {
  id          String           @id @default(cuid())
  userId      String
  imageUrl    String
  displayName String           @db.VarChar(100)
  kitName     String           @db.VarChar(200)
  likeCount   Int              @default(0)
  status      ModerationStatus @default(PENDING)
  isFeatured  Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user  User       @relation(fields: [userId], references: [id])
  tags  PhotoTag[]
  likes PhotoLike[]
  saves PhotoSave[]
}

model PhotoTag {
  id      String    @id @default(cuid())
  photoId String
  tag     String    @db.VarChar(50)
  source  TagSource @default(MANUAL)

  photo GalleryPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

model PhotoLike {
  id        String   @id @default(cuid())
  photoId   String
  userId    String
  createdAt DateTime @default(now())

  photo GalleryPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id])

  @@unique([photoId, userId])
}

model PhotoSave {
  id        String   @id @default(cuid())
  photoId   String
  userId    String
  createdAt DateTime @default(now())

  photo GalleryPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id])

  @@unique([photoId, userId])
}

// ==================== REVIEWS ====================

model Review {
  id         String           @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  text       String           @db.VarChar(2000)
  status     ModerationStatus @default(PENDING)
  isFeatured Boolean          @default(false)
  aiSummary  String?          @db.VarChar(150)
  createdAt  DateTime         @default(now())

  user    User          @relation(fields: [userId], references: [id])
  product Product       @relation(fields: [productId], references: [id])
  photos  ReviewPhoto[]

  @@unique([userId, productId])
}

model ReviewPhoto {
  id       String @id @default(cuid())
  reviewId String
  url      String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ==================== GAMIFICATION ====================

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  imageUrl    String
  criteria    String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Challenge {
  id              String          @id @default(cuid())
  title           String          @db.VarChar(200)
  description     String          @db.VarChar(2000)
  imageUrl        String?
  submissionStart DateTime
  submissionEnd   DateTime
  votingStart     DateTime
  votingEnd       DateTime
  minEntries      Int             @default(3)
  status          ChallengeStatus @default(UPCOMING)
  createdAt       DateTime        @default(now())

  entries ChallengeEntry[]
}

model ChallengeEntry {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  imageUrl    String
  description String   @db.VarChar(500)
  voteCount   Int      @default(0)
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  votes     Vote[]
}

model ContestEntry {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  imageUrl  String
  voteCount Int      @default(0)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  votes Vote[]
}

model Vote {
  id               String   @id @default(cuid())
  userId           String
  challengeEntryId String?
  contestEntryId   String?
  createdAt        DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id])
  challengeEntry ChallengeEntry? @relation(fields: [challengeEntryId], references: [id])
  contestEntry   ContestEntry?   @relation(fields: [contestEntryId], references: [id])
}

// ==================== INSTAGRAM ====================

model InstagramPost {
  id         String           @id @default(cuid())
  postUrl    String?
  imageUrl   String
  caption    String           @db.VarChar(2200)
  username   String           @db.VarChar(100)
  likeCount  Int              @default(0)
  postDate   DateTime
  status     ModerationStatus @default(PENDING)
  isFeatured Boolean          @default(false)
  syncedAt   DateTime         @default(now())
  createdAt  DateTime         @default(now())
}

// ==================== COMMUNITY STORIES ====================

model CommunityStory {
  id           String           @id @default(cuid())
  userId       String?
  name         String           @db.VarChar(50)
  age          Int
  reviewText   String           @db.VarChar(1000)
  photoUrl     String
  artworkUrl   String
  status       ModerationStatus @default(PENDING)
  rejectReason String?
  createdAt    DateTime         @default(now())
}

// ==================== ADMIN ====================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String    @db.VarChar(100)
  passwordHash String
  role         AdminRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  statusHistory StatusHistory[]
}

// ==================== CMS ====================

model CMSContent {
  id          String    @id @default(cuid())
  section     String    @unique
  content     Json
  version     Int       @default(1)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== BIRTHDAY INQUIRIES ====================

model BirthdayInquiry {
  id               String        @id @default(cuid())
  name             String        @db.VarChar(100)
  phone            String        @db.VarChar(20)
  email            String
  partyDate        DateTime
  numberOfChildren Int
  packageTier      PackageTier
  theme            String        @db.VarChar(100)
  message          String?       @db.VarChar(500)
  status           InquiryStatus @default(NEW)
  createdAt        DateTime      @default(now())
}

// ==================== NOTIFICATIONS ====================

model NotificationLog {
  id          String             @id @default(cuid())
  recipientId String?
  email       String
  type        NotificationType
  subject     String
  status      NotificationStatus @default(PENDING)
  retryCount  Int                @default(0)
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
}

model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  optedIn Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ==================== NEWSLETTER ====================

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== CART ====================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

// ==================== WISHLIST ====================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

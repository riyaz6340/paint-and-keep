# Paint & Keep - Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================================
# DEPLOYMENT STACK (all free tier):
# - Vercel (hosting)
# - Supabase or Neon (PostgreSQL)
# - Cloudinary (images: 25GB storage, 25GB bandwidth/month)
# - Upstash (Redis)
# - Resend (email, 100/day)
# - GoDaddy (domain, point to Vercel)
# ============================================================

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL - Supabase or Neon free tier)
DATABASE_URL="postgresql://postgres:password@localhost:5432/paint_and_keep"

# Redis (Upstash free tier - use the standard Redis protocol endpoint)
REDIS_URL=redis://localhost:6379

# Cloudinary (free tier: 25GB storage, 25GB bandwidth/month)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Payment Gateways
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Authentication
JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend - free tier: 100 emails/day)
RESEND_API_KEY=
EMAIL_FROM=noreply@paintandkeep.com

# OpenAI
OPENAI_API_KEY=

# Instagram
INSTAGRAM_ACCESS_TOKEN=

# Analytics
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
